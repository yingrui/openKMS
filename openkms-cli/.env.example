# -----------------------------------------------------------------------------
# Authentication — must match backend OPENKMS_AUTH_MODE (default dev: local)
# -----------------------------------------------------------------------------
OPENKMS_AUTH_MODE=local
OPENKMS_CLI_BASIC_USER=openkms-cli
OPENKMS_CLI_BASIC_PASSWORD=change-me

# --- OIDC (set OPENKMS_AUTH_MODE=oidc and configure service client) ---
# Default token URL: {OPENKMS_OIDC_AUTH_SERVER_BASE_URL}/realms/{OPENKMS_OIDC_REALM}/protocol/openid-connect/token
# OPENKMS_OIDC_TOKEN_URL=https://your-idp.example.com/oauth/token
# OPENKMS_OIDC_AUTH_SERVER_BASE_URL=http://localhost:8081
# OPENKMS_OIDC_REALM=openkms
# OPENKMS_OIDC_SERVICE_CLIENT_ID=openkms-cli
# OPENKMS_OIDC_SERVICE_CLIENT_SECRET=openkms-cli-secret

# S3/MinIO (for pipeline upload)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_ENDPOINT_URL=http://localhost:9000
AWS_BUCKET_NAME=openkms

# VLM Server (mlx-vlm for document parsing)
OPENKMS_VLM_URL=http://localhost:8101
# OPENKMS_VLM_API_KEY=  # Optional; for authenticated VLM endpoints

# Embedding model (kb-index pipeline; overrides KB's configured model when set)
# OPENKMS_EMBEDDING_MODEL_BASE_URL=http://localhost:8080/api/v1
# OPENKMS_EMBEDDING_MODEL_API_KEY=sk-xxx
# OPENKMS_EMBEDDING_MODEL_NAME=text-embedding-3-small

# Backend API URL (for PUT metadata when --extract-metadata)
OPENKMS_API_URL=http://localhost:8102

# Metadata extraction LLM API key when using --extraction-model-base-url (not --extraction-model-name)
# OPENKMS_EXTRACTION_MODEL_API_KEY=sk-xxx
# Legacy alias: EXTRACTION_MODEL_API_KEY (same meaning)

# AWS region (pipeline S3)
# AWS_REGION=us-east-1
