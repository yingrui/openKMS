# -----------------------------------------------------------------------------
# Authentication (must match backend OPENKMS_AUTH_MODE)
# -----------------------------------------------------------------------------
# oidc (default): client credentials against your IdP (e.g. Keycloak).
# local: HTTP Basic to the openKMS API — set the same user/password as backend OPENKMS_CLI_BASIC_*.
#
# OPENKMS_AUTH_MODE=oidc

# --- OIDC mode (OPENKMS_AUTH_MODE unset or oidc) ---
# IdP base URL and realm (token URL = {AUTH_URL}/realms/{AUTH_REALM}/protocol/openid-connect/token)
AUTH_URL=http://localhost:8081
AUTH_REALM=openkms
AUTH_CLIENT_ID=openkms-cli
AUTH_CLIENT_SECRET=openkms-cli-secret

# --- Local mode (OPENKMS_AUTH_MODE=local) ---
# Uncomment and align with backend .env (OPENKMS_CLI_BASIC_USER / OPENKMS_CLI_BASIC_PASSWORD).
# OPENKMS_AUTH_MODE=local
# OPENKMS_CLI_BASIC_USER=openkms-cli
# OPENKMS_CLI_BASIC_PASSWORD=change-me

# S3/MinIO (for pipeline upload)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_ENDPOINT_URL=http://localhost:9000
AWS_BUCKET_NAME=openkms

# VLM Server (mlx-vlm for document parsing)
OPENKMS_VLM_URL=http://localhost:8101
# OPENKMS_VLM_API_KEY=  # Optional; for authenticated VLM endpoints

# Embedding model (kb-index pipeline; overrides KB's configured model when set)
# OPENKMS_EMBEDDING_MODEL_BASE_URL=http://localhost:8080/api/v1
# OPENKMS_EMBEDDING_MODEL_API_KEY=sk-xxx
# OPENKMS_EMBEDDING_MODEL_NAME=text-embedding-3-small

# Backend API URL (for PUT metadata when --extract-metadata)
OPENKMS_API_URL=http://localhost:8102
