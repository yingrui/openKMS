# Copy to .env — must match backend OPENKMS_AUTH_MODE (default dev: local).
OPENKMS_AUTH_MODE=local
OPENKMS_CLI_BASIC_USER=openkms-cli
OPENKMS_CLI_BASIC_PASSWORD=change-me

# OIDC when OPENKMS_AUTH_MODE=oidc (token_endpoint from IdP .well-known/openid-configuration):
# OPENKMS_OIDC_TOKEN_URL=http://localhost:8081/realms/openkms/protocol/openid-connect/token
# OPENKMS_CLI_OIDC_CLIENT_ID=openkms-cli
# OPENKMS_CLI_OIDC_CLIENT_SECRET=

# S3/MinIO (pipeline upload)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_ENDPOINT_URL=http://localhost:9000
AWS_BUCKET_NAME=openkms
AWS_REGION=us-east-1

# Backend API base (required to fetch document-parse defaults when OPENKMS_VLM_* are unset; needs CLI auth).
OPENKMS_API_URL=http://localhost:8102

# kb-index: credentials come from GET /internal-api/models/kb-embedding-credentials (same auth as OPENKMS_API_URL).
# Optional overrides only:
# OPENKMS_EMBEDDING_MODEL_API_KEY=
# OPENKMS_EMBEDDING_MODEL_BASE_URL=
# OPENKMS_EMBEDDING_MODEL_NAME=
# Optional overrides (omit to use GET /internal-api/models/document-parse-defaults when authenticated):
# OPENKMS_VLM_URL=http://localhost:8101
OPENKMS_VLM_MODEL=PaddlePaddle/PaddleOCR-VL-1.6
# OPENKMS_VLM_API_KEY=

# Baidu Cloud OCR (baidu-doc-parse pipeline)
OPENKMS_BAIDU_CLOUD_API_KEY=your-baidu-cloud-api-key
OPENKMS_BAIDU_CLOUD_SECRET_KEY=your-baidu-cloud-secret-key
# Private BOS bucket for temporary staging (presigned file_url to paddle-vl-parser)
OPENKMS_BAIDU_BOS_BUCKET=your-baidu-bos-bucket
# IAM Access Key — NOT the OCR API Key; 控制台 → 安全认证 → Access Key
OPENKMS_BAIDU_BOS_ACCESS_KEY=your-bos-access-key-id
OPENKMS_BAIDU_BOS_SECRET_KEY=your-bos-secret-access-key
# OPENKMS_BAIDU_BOS_ENDPOINT=bj.bcebos.com
# OPENKMS_BAIDU_BOS_PREFIX=openkms-temp
# OPENKMS_BAIDU_BOS_PRESIGN_TTL_SECONDS=3600
# file_url submit retries on Baidu url-download timeout (282112)
# OPENKMS_BAIDU_FILE_URL_SUBMIT_RETRIES=3
# OPENKMS_BAIDU_FILE_URL_RETRY_DELAY_SECONDS=20
# OPENKMS_BAIDU_FILE_URL_SUBMIT_TIMEOUT_SECONDS=600
# CLI log level for Worker output stderr (default INFO): DEBUG, WARNING, …
# OPENKMS_CLI_LOG_LEVEL=INFO
# Optional API endpoints (defaults match Baidu official PaddleOCR-VL doc):
BAIDU_TOKEN_URL=https://aip.baidubce.com/oauth/2.0/token
BAIDU_TASK_URL=https://aip.baidubce.com/rest/2.0/brain/online/v2/paddle-vl-parser/task
BAIDU_QUERY_URL=https://aip.baidubce.com/rest/2.0/brain/online/v2/paddle-vl-parser/task/query