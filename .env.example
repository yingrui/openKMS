# openKMS environment variables reference
# Copy backend/.env.example to backend/.env and configure.
# See backend/app/config.py for all supported vars.

# Core services (use with docker-compose):
# - Postgres: localhost:5432 (user: postgres, db: openkms)
# - MinIO: localhost:9000 (minioadmin/minioadmin)

# Key vars for backend/.env:
# OPENKMS_DATABASE_HOST=localhost
# OPENKMS_DATABASE_PASSWORD=postgres
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_ENDPOINT_URL=http://localhost:9000
# OPENKMS_AUTH_MODE=oidc
# OPENKMS_OIDC_ISSUER=http://localhost:8081/realms/openkms
# (or OPENKMS_OIDC_AUTH_SERVER_BASE_URL + OPENKMS_OIDC_REALM if issuer is unset)
# OPENKMS_FRONTEND_URL=http://localhost:5173
# OPENKMS_OIDC_REDIRECT_URI=http://localhost:8102/login/oauth2/code/oidc
# openkms-cli/.env: OPENKMS_OIDC_SERVICE_CLIENT_SECRET (+ base/realm or OPENKMS_OIDC_TOKEN_URL)
# OPENKMS_VLM_URL=http://localhost:8101
