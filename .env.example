# openKMS environment variables reference
# Copy backend/.env.example → backend/.env and configure.
# See backend/app/config.py for all supported vars.

# Core services (see docker/docker-compose.yml):
# - Postgres: localhost:5432 (user postgres / password postgres, db openkms)
# - MinIO: localhost:9000 (minioadmin / minioadmin)

# Default dev auth: local users + HTTP Basic for CLI (see backend/.env.example).
# OPENKMS_AUTH_MODE=local
# OPENKMS_CLI_BASIC_USER / OPENKMS_CLI_BASIC_PASSWORD — match backend and openkms-cli/.env

# Key vars for backend/.env:
# OPENKMS_DATABASE_HOST=localhost
# OPENKMS_DATABASE_PASSWORD=postgres
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_ENDPOINT_URL=http://localhost:9000
# OPENKMS_FRONTEND_URL=http://localhost:5173
# For OIDC instead: OPENKMS_AUTH_MODE=oidc, OPENKMS_OIDC_ISSUER=..., OPENKMS_OIDC_REDIRECT_URI=...
# openkms-cli with OIDC: OPENKMS_OIDC_SERVICE_CLIENT_SECRET (+ issuer or token URL)
# OPENKMS_VLM_URL=http://localhost:8101
