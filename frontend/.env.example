# Backend API. In dev, leave unset to use Vite proxy (avoids CORS). For production or custom backend:
# VITE_API_URL=http://localhost:8102

# Must match OPENKMS_AUTH_MODE on the backend (default dev: local).
VITE_AUTH_MODE=local

# OIDC SPA (only when backend uses OPENKMS_AUTH_MODE=oidc). Issuer = IdP /.well-known parent.
# VITE_OIDC_ISSUER=http://localhost:8081/realms/openkms
# VITE_OIDC_CLIENT_ID=openkms-frontend
# If VITE_OIDC_ISSUER is unset, authority = {VITE_OIDC_AUTH_SERVER_BASE_URL}/realms/{VITE_OIDC_REALM}
# VITE_OIDC_AUTH_SERVER_BASE_URL=http://localhost:8081
# VITE_OIDC_REALM=openkms
# Register redirect URIs: {origin}/auth/callback and {origin}/auth/silent-renew (public client + PKCE)
