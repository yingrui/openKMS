# Backend API. In dev, leave unset to use Vite proxy (avoids CORS). For production or custom backend:
# VITE_API_URL=http://localhost:8102

# Fallback auth mode if the API is unreachable; normally the UI uses GET /api/auth/public-config
# (must match OPENKMS_AUTH_MODE on the backend).
# VITE_AUTH_MODE=local

# OIDC IdP / Keycloak (when the server runs OPENKMS_AUTH_MODE=oidc)
# VITE_KEYCLOAK_URL=http://localhost:8081
# VITE_KEYCLOAK_REALM=openkms
# VITE_KEYCLOAK_CLIENT_ID=openkms-frontend
