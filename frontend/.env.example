# Copy to frontend/.env for local Vite dev.

# Leave unset in dev to use the Vite proxy (same origin, no CORS).
# VITE_API_URL=http://localhost:8102

# Fallback if /api/auth/public-config is unreachable; keep aligned with backend OPENKMS_AUTH_MODE.
VITE_AUTH_MODE=local

# OIDC SPA only when backend uses OPENKMS_AUTH_MODE=oidc (see docs).
# VITE_OIDC_ISSUER=http://localhost:8081/realms/openkms
# VITE_OIDC_CLIENT_ID=openkms-frontend
# VITE_OIDC_AUTH_SERVER_BASE_URL=http://localhost:8081
# VITE_OIDC_REALM=openkms

# Build stamp (6-char git hash). Auto-set from git in vite.config.ts dev/build; docker/build-and-run.sh sets it for images.
# VITE_APP_VERSION=0028cf0
