# Backend API (must match backend port, default 8102)
VITE_API_URL=http://localhost:8102

# Direct object storage (S3/MinIO public URL, bucket must allow public read). No trailing slash.
# Example for MinIO: http://localhost:9000/openkms
VITE_STORAGE_BASE_URL=

# Keycloak (optional)
# VITE_KEYCLOAK_URL=http://localhost:8081
# VITE_KEYCLOAK_REALM=openkms
# VITE_KEYCLOAK_CLIENT_ID=openkms-frontend
