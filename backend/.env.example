# Copy to backend/.env and edit.
# Full variable list: docs/features/configuration.md

# --- Auth: local | oidc ---
OPENKMS_AUTH_MODE=local
OPENKMS_ALLOW_SIGNUP=true
OPENKMS_LOCAL_JWT_EXP_HOURS=168
OPENKMS_SECRET_KEY=openkms-dev-secret-change-in-production

# HTTP Basic (local mode only; same values on openkms-cli, worker, scheduler, qa-agent)
OPENKMS_CLI_BASIC_USER=openkms-cli
OPENKMS_CLI_BASIC_PASSWORD=change-me
OPENKMS_WORKER_BASIC_USER=openkms-worker
OPENKMS_WORKER_BASIC_PASSWORD=change-me
OPENKMS_QA_AGENT_BASIC_USER=qa-agent
OPENKMS_QA_AGENT_BASIC_PASSWORD=change-me

# OIDC (when OPENKMS_AUTH_MODE=oidc) — see docs/features/console-and-auth.md
# OPENKMS_OIDC_ISSUER=http://localhost:8081/realms/openkms
# OPENKMS_OIDC_CLIENT_ID=openkms-backend
# OPENKMS_OIDC_CLIENT_SECRET=
# OPENKMS_FRONTEND_URL=http://localhost:5173
# OPENKMS_INTERNAL_SERVICE_CLIENT_IDS=openkms-cli,qa-agent,openkms-worker
# OPENKMS_OIDC_TOKEN_URL=http://localhost:8081/realms/openkms/protocol/openid-connect/token
# OPENKMS_CLI_OIDC_CLIENT_ID=openkms-cli
# OPENKMS_CLI_OIDC_CLIENT_SECRET=
# OPENKMS_WORKER_OIDC_CLIENT_ID=openkms-worker
# OPENKMS_WORKER_OIDC_CLIENT_SECRET=

# --- PostgreSQL ---
OPENKMS_DATABASE_HOST=localhost
OPENKMS_DATABASE_PORT=5432
OPENKMS_DATABASE_USER=postgres
OPENKMS_DATABASE_PASSWORD=postgres
OPENKMS_DATABASE_NAME=openkms

# --- MinIO / S3 ---
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_ENDPOINT_URL=http://localhost:9000
AWS_BUCKET_NAME=openkms
AWS_REGION=us-east-1

# --- Document parse (mlx-vlm / PaddleOCR-VL) ---
OPENKMS_VLM_URL=http://localhost:8101

# --- Baidu doc-parse pipeline (optional) ---
OPENKMS_BAIDU_CLOUD_API_KEY=
OPENKMS_BAIDU_CLOUD_SECRET_KEY=
OPENKMS_BAIDU_BOS_BUCKET=
OPENKMS_BAIDU_BOS_ACCESS_KEY=
OPENKMS_BAIDU_BOS_SECRET_KEY=
