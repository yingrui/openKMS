# Authentication: oidc (external OpenID Connect IdP) | local (PostgreSQL users + /api/auth/*)
OPENKMS_AUTH_MODE=local
OPENKMS_ALLOW_SIGNUP=true
# First local signup becomes admin (is_admin); later signups are regular users. No default password — use /signup.
OPENKMS_LOCAL_JWT_EXP_HOURS=168
# Local mode only: credentials the API accepts on HTTP Basic (e.g. automation clients). Not OIDC.
# Same values must be set on clients that use Basic (see openkms-cli/.env); secrets are not stored here for OIDC.
OPENKMS_CLI_BASIC_USER=openkms-cli
OPENKMS_CLI_BASIC_PASSWORD=change-me
OPENKMS_QA_AGENT_BASIC_USER=qa-agent
OPENKMS_QA_AGENT_BASIC_PASSWORD=change-me

# OIDC IdP (backend OAuth callback + JWT verification via issuer discovery)
# Preferred: full issuer URL (must match token "iss"; metadata at {issuer}/.well-known/openid-configuration)
# OPENKMS_OIDC_ISSUER=http://localhost:8081/realms/openkms
# If OPENKMS_OIDC_ISSUER is unset, issuer = {OPENKMS_OIDC_AUTH_SERVER_BASE_URL}/realms/{OPENKMS_OIDC_REALM}
# OPENKMS_OIDC_AUTH_SERVER_BASE_URL=http://localhost:8081
# OPENKMS_OIDC_REALM=openkms
# OPENKMS_OIDC_CLIENT_ID=openkms-backend
# OPENKMS_OIDC_CLIENT_SECRET=openkms-backend-secret
# Backend OAuth redirect URI — register on the IdP confidential client (authorization code)
# OPENKMS_OIDC_REDIRECT_URI=http://localhost:8102/login/oauth2/code/oidc
# SPA origin (CORS + redirects)
# OPENKMS_FRONTEND_URL=http://localhost:5173
# Baidu BOS staging for baidu-doc-parse (worker passes to openkms-cli)
# OPENKMS_BAIDU_BOS_BUCKET=your-baidu-bos-bucket
# OPENKMS_BAIDU_BOS_ACCESS_KEY=your-bos-access-key-id
# OPENKMS_BAIDU_BOS_SECRET_KEY=your-bos-secret-access-key
# OPENKMS_BAIDU_BOS_ENDPOINT=bj.bcebos.com
# OPENKMS_BAIDU_BOS_PREFIX=openkms-temp
# OPENKMS_BAIDU_BOS_PRESIGN_TTL_SECONDS=3600
# file_url submit retries when Baidu returns url-download timeout (282112)
# OPENKMS_BAIDU_FILE_URL_SUBMIT_RETRIES=3
# OPENKMS_BAIDU_FILE_URL_RETRY_DELAY_SECONDS=20
# OPENKMS_BAIDU_FILE_URL_SUBMIT_TIMEOUT_SECONDS=600
# Browser client id for RP-initiated logout (post_logout_redirect_uri)
# OPENKMS_OIDC_POST_LOGOUT_CLIENT_ID=openkms-frontend
# Comma-separated OIDC client ids allowed on /internal-api; first id is local-cli JWT azp.
# OPENKMS_INTERNAL_SERVICE_CLIENT_IDS=openkms-cli,qa-agent

# PostgreSQL
OPENKMS_DATABASE_HOST=localhost
OPENKMS_DATABASE_PORT=5432
OPENKMS_DATABASE_USER=postgres
OPENKMS_DATABASE_PASSWORD=postgres
OPENKMS_DATABASE_NAME=openkms

# S3/MinIO Configuration
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_ENDPOINT_URL=http://localhost:9000
AWS_BUCKET_NAME=openkms
# SigV4 signing region (MinIO ignores the value; us-east-1 is the usual default). Set your real region for AWS S3.
AWS_REGION=us-east-1

# Signs openkms_session cookie (local + OIDC after sync-session) and local-mode HS256 JWTs.
# Also used as dev fallback for data-source Fernet encryption. Use a strong random value in production.
OPENKMS_SECRET_KEY=openkms-dev-secret-change-in-production

# Verbose SQL logs (default off). OPENKMS_DEBUG does not enable this.
# OPENKMS_SQL_ECHO=true

# Cache GET /api/auth/permission-catalog in-process (seconds; 0 = always hit DB). Default 5.
# OPENKMS_PERMISSION_CATALOG_CACHE_SECONDS=5

# Optional: strict permission pattern enforcement for /api (see docs/security.md). Default false.
# OPENKMS_ENFORCE_PERMISSION_PATTERNS_STRICT=false
# OPENKMS_PERMISSION_PATTERN_CACHE_TTL_SECONDS=60

# Document pipeline worker: max wait for openkms-cli pipeline run (VLM + optional metadata extraction). Default 3600.
OPENKMS_PIPELINE_TIMEOUT_SECONDS=7200

# Max characters stored per job worker log (command + stderr + stdout); larger output is truncated with a middle marker. Default 262144; minimum 4096.
# OPENKMS_JOB_LOG_MAX_CHARS=262144

# Wiki embedded agent (LangGraph): optional JSON merged into ChatOpenAI extra_body.
# Thinking/reasoning mode is not supported — enable_thinking is always forced false after merge.
# OPENKMS_AGENT_LLM_EXTRA_BODY={"some_provider_flag":true}
# Some OpenAI-compatible gateways (tool loops): force empty reasoning_content on assistant rows if base_url is a generic proxy — see OPENKMS_AGENT_LLM_REASONING_CONTENT_SHIM in docs/features/configuration.md (legacy alias: OPENKMS_AGENT_DASHSCOPE_REASONING_SHIM).
# OPENKMS_AGENT_LLM_REASONING_CONTENT_SHIM=true

# Wiki agent: max DB messages loaded into one LLM turn (tail of thread). Default 120; max 500.
# OPENKMS_AGENT_WIKI_MAX_CONTEXT_MESSAGES=120

# KB Q&A → qa-agent: max prior messages in conversation_history per turn (tail). Default 120; max 500.
# OPENKMS_AGENT_KB_QA_MAX_CONTEXT_MESSAGES=120

# Optional Langfuse for the embedded wiki agent (same env names as qa-agent; omit to disable).
# LANGFUSE_SECRET_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_BASE_URL=
# LANGFUSE_TRACE_STREAMING=true
# LANGFUSE_HEALTHCHECK=true

# Agent workspace projects (on-disk folders for Deep Agents). Default: data/projects under backend cwd.
# OPENKMS_PROJECTS_ROOT=data/projects
# OPENKMS_AGENT_SKILLS_ROOT=data/agent-skills
# OPENKMS_DEEP_AGENT_MODEL_ID=
# OPENKMS_AGENT_SANDBOX_TIMEOUT_SECONDS=60

# VLM Server (mlx-vlm / PaddleOCR-VL document parsing — default port 8101; not an OpenAI /api/v1 URL).
OPENKMS_VLM_URL=http://localhost:8101

OPENKMS_BAIDU_CLOUD_API_KEY=your-baidu-cloud-api-key
OPENKMS_BAIDU_CLOUD_SECRET_KEY=your-baidu-cloud-secret-key
OPENKMS_BAIDU_BOS_BUCKET=your-baidu-bos-bucket
OPENKMS_BAIDU_BOS_ACCESS_KEY=your-bos-access-key-id
OPENKMS_BAIDU_BOS_SECRET_KEY=your-bos-secret-access-key