# Authentication: oidc (external IdP, Keycloak env below) | local (PostgreSQL users + /api/auth/*)
OPENKMS_AUTH_MODE=local
OPENKMS_ALLOW_SIGNUP=true
# Grant is_admin when a new signup's username matches (case-insensitive). No default password — use /signup.
OPENKMS_INITIAL_ADMIN_USER=admin
OPENKMS_LOCAL_JWT_EXP_HOURS=168
# HTTP Basic for openkms-cli when AUTH_MODE=local (use only on trusted networks without TLS)
OPENKMS_CLI_BASIC_USER=openkms-cli
OPENKMS_CLI_BASIC_PASSWORD=change-me

# PostgreSQL
OPENKMS_DATABASE_HOST=localhost
OPENKMS_DATABASE_PORT=5432
OPENKMS_DATABASE_USER=postgres
OPENKMS_DATABASE_PASSWORD=
OPENKMS_DATABASE_NAME=openkms

# Keycloak (OAuth2 authorization code flow)
KEYCLOAK_AUTH_SERVER_URL=http://localhost:8081
KEYCLOAK_REALM=openkms
KEYCLOAK_CLIENT_ID=openkms-backend
KEYCLOAK_CLIENT_SECRET=openkms-backend-secret
# Redirect URI - must match Keycloak client "Valid Redirect URIs"
KEYCLOAK_REDIRECT_URI=http://localhost:8102/login/oauth2/code/keycloak
# Frontend URL - where to redirect after login/logout
KEYCLOAK_FRONTEND_URL=http://localhost:5173
# Client ID for logout redirect (default: openkms-frontend; must have KEYCLOAK_FRONTEND_URL in "Valid Post Logout Redirect URIs")
# KEYCLOAK_LOGOUT_CLIENT_ID=openkms-frontend

# S3/MinIO Configuration
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_ENDPOINT_URL=http://localhost:9000
AWS_BUCKET_NAME=openkms

# Session (for OAuth2 session cookie signing; use strong secret in production)
OPENKMS_SECRET_KEY=openkms-dev-secret-change-in-production

# VLM Server (mlx-vlm for document parsing)
OPENKMS_VLM_URL=http://localhost:8101
# OPENKMS_VLM_API_KEY=  # Optional; for authenticated VLM endpoints

# Embedding model (kb-index pipeline; overrides KB's configured model when set)
OPENKMS_EMBEDDING_MODEL_BASE_URL=http://localhost:8080/api/v1
OPENKMS_EMBEDDING_MODEL_API_KEY=sk-xxx
OPENKMS_EMBEDDING_MODEL_NAME=bge-m3