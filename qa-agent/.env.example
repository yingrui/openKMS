# Copy to qa-agent/.env for local runs (outside Docker). LLM URL/model/key come from backend models APIs
# (GET /internal-api/models/llm-defaults) when OPENKMS_LLM_MODEL_* are unset.
# Docker Compose injects env via docker-compose.yml ``environment`` only (see docker/README.md).
# Local dev: copy this file to qa-agent/.env. Compose: optional ``--env-file backend/.env`` for ${...} substitution.

OPENKMS_BACKEND_URL=http://localhost:8102

# Local mode (align with backend/.env):
# OPENKMS_QA_AGENT_AUTH_MODE=local
# OPENKMS_QA_AGENT_BASIC_USER=openkms-cli
# OPENKMS_QA_AGENT_BASIC_PASSWORD=change-me
# Compatibility aliases: OPENKMS_AUTH_MODE, OPENKMS_CLI_BASIC_USER, OPENKMS_CLI_BASIC_PASSWORD

# OIDC mode (align with openkms-cli/.env):
# OPENKMS_QA_AGENT_AUTH_MODE=oidc
# OPENKMS_QA_AGENT_OIDC_AUTH_SERVER_BASE_URL=http://localhost:8081
# OPENKMS_QA_AGENT_OIDC_REALM=openkms
# OPENKMS_QA_AGENT_OIDC_SERVICE_CLIENT_ID=openkms-cli
# OPENKMS_QA_AGENT_OIDC_SERVICE_CLIENT_SECRET=...
# Compatibility aliases: OPENKMS_OIDC_*

# Optional LLM overrides (omit to use Console → Models default LLM):
# OPENKMS_LLM_MODEL_BASE_URL=http://localhost:11434/v1
# OPENKMS_LLM_MODEL_API_KEY=no-key
# OPENKMS_LLM_MODEL_NAME=qwen2.5

# Same thinking / reasoning_content behavior as wiki copilot (see docs/features/configuration.md).
# Optional JSON merged into ChatOpenAI extra_body; enable_thinking is always forced false after merge.
# OPENKMS_LLM_EXTRA_BODY={}
# Or reuse: OPENKMS_AGENT_LLM_EXTRA_BODY={}
# OPENKMS_LLM_REASONING_CONTENT_SHIM=auto  # default when unset: shim on except api.openai.com
# Aliases: OPENKMS_AGENT_LLM_REASONING_CONTENT_SHIM, OPENKMS_AGENT_DASHSCOPE_REASONING_SHIM

# Optional — cross-encoder rerank (OpenAI-style POST {base}/v1/rerank). Default is off
# (many LLM gateways return 404). Set OPENKMS_RERANK_ENABLED=true and point OPENKMS_RERANK_BASE_URL
# at a host that implements /v1/rerank when you have one (e.g. SiliconFlow).
# OPENKMS_RERANK_BASE_URL=https://api.siliconflow.cn/v1
# OPENKMS_RERANK_ENABLED=true

HOST=0.0.0.0
PORT=8103

# Optional — Langfuse (requires all three: secret, public, **LANGFUSE_BASE_URL**)
# LANGFUSE_SECRET_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_BASE_URL=http://localhost:3000
# If LANGFUSE_HEALTHCHECK=true (default), qa-agent probes GET {LANGFUSE_BASE_URL}/api/public/health
# before attaching callbacks; while down, all sessions skip Langfuse until the next probe
# (LANGFUSE_HEALTHCHECK_RETRY_SECONDS, default 60). Set LANGFUSE_HEALTHCHECK=false to disable the probe.
# LANGFUSE_HEALTHCHECK_RETRY_SECONDS=60
# Default true: attaches Langfuse to astream_events (NDJSON /ask/stream). Some setups log
# OpenTelemetry "Failed to detach context"; set false to trace non-streaming /ask only.
# LANGFUSE_TRACE_STREAMING=false
