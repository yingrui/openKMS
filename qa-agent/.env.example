# Copy to qa-agent/.env (local runs). Docker: see docker/docker-compose.yml.
# LLM defaults: GET /internal-api/models/llm-defaults when OPENKMS_LLM_MODEL_* are unset.

OPENKMS_BACKEND_URL=http://localhost:8102

# Auth — match backend OPENKMS_AUTH_MODE
OPENKMS_AUTH_MODE=local
OPENKMS_QA_AGENT_BASIC_USER=qa-agent
OPENKMS_QA_AGENT_BASIC_PASSWORD=change-me

# OIDC (replace local block above):
# OPENKMS_AUTH_MODE=oidc
# OPENKMS_OIDC_TOKEN_URL=http://localhost:8081/realms/openkms/protocol/openid-connect/token
# OPENKMS_QA_AGENT_OIDC_CLIENT_ID=qa-agent
# OPENKMS_QA_AGENT_OIDC_CLIENT_SECRET=

# Optional LLM overrides
# OPENKMS_LLM_MODEL_BASE_URL=
# OPENKMS_LLM_MODEL_API_KEY=
# OPENKMS_LLM_MODEL_NAME=

HOST=0.0.0.0
PORT=8103

# Logging: INFO = turn/tool summaries; DEBUG = tool I/O payloads, questions, LangGraph gaps
# OPENKMS_QA_AGENT_LOG_LEVEL=DEBUG

# LangGraph tool/model loop cap (default 200; was 25 when unset). Alias: OPENKMS_AGENT_RECURSION_LIMIT
# OPENKMS_QA_AGENT_RECURSION_LIMIT=200

# Optional Langfuse (same env names as backend; omit all three keys + base URL to disable).
# LANGFUSE_SECRET_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_BASE_URL=
# LANGFUSE_TRACE_STREAMING=true
# LANGFUSE_HEALTHCHECK=true
# LANGFUSE_HEALTHCHECK_RETRY_SECONDS=60

# Optional — rerank (default off)
# OPENKMS_RERANK_ENABLED=true
# OPENKMS_RERANK_BASE_URL=
