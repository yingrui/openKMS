# openKMS backend URL (for knowledge base search API).
# Default backend dev uses OPENKMS_AUTH_MODE=local; configure tokens/session per your deployment.
OPENKMS_BACKEND_URL=http://localhost:8102

# LLM for answer generation (OpenAI-compatible)
OPENKMS_LLM_MODEL_BASE_URL=http://localhost:8080/api/v1
OPENKMS_LLM_MODEL_API_KEY=sk-...
OPENKMS_LLM_MODEL_NAME=qwen3.5

# Server
HOST=0.0.0.0
PORT=8103

# Langfuse
LANGFUSE_SECRET_KEY="sk-..."
LANGFUSE_PUBLIC_KEY="pk-..."
LANGFUSE_BASE_URL="http://localhost:3002"