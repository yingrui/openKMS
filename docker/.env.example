# Docker Compose overrides for openKMS (copy to docker/.env and edit).
#
#   cd docker
#   cp .env.example .env
#   docker compose up -d --build
#
# Compose loads docker/.env automatically (same directory as docker-compose.yml).
# From repo root: docker compose -f docker/docker-compose.yml up -d --build
# (--env-file docker/.env is optional; not required when the file is docker/.env)
# These values substitute ${VAR} in docker-compose.yml only — they are not
# mounted into containers as an env_file. Do not edit docker-compose.yml for
# routine overrides.
#
# OIDC: compose defaults to local auth. Switching to OIDC also requires
# OPENKMS_OIDC_* on backend/worker (see backend/.env.example) and rebuilding
# the frontend with VITE_AUTH_MODE=oidc (not covered by this file alone).

# --- Build mirrors (China defaults in compose; empty = upstream) ---
APT_MIRROR=mirrors.aliyun.com
UV_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
UV_EXTRA_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
NPM_REGISTRY=https://registry.npmmirror.com

# --- Auth (local mode defaults) ---
OPENKMS_AUTH_MODE=local
OPENKMS_ALLOW_SIGNUP=true
OPENKMS_LOCAL_JWT_EXP_HOURS=168
OPENKMS_SECRET_KEY=openkms-dev-secret-change-in-production
OPENKMS_INTERNAL_SERVICE_CLIENT_IDS=openkms-cli,qa-agent

# HTTP Basic for automation (worker → openkms-cli, qa-agent → backend)
OPENKMS_CLI_BASIC_USER=openkms-cli
OPENKMS_CLI_BASIC_PASSWORD=change-me
OPENKMS_QA_AGENT_BASIC_USER=qa-agent
OPENKMS_QA_AGENT_BASIC_PASSWORD=change-me

# --- Database (app services; postgres container uses compose defaults) ---
OPENKMS_DATABASE_HOST=postgres
OPENKMS_DATABASE_USER=postgres
OPENKMS_DATABASE_PASSWORD=postgres
OPENKMS_DATABASE_NAME=openkms

# --- MinIO / S3 (app services use http://minio:9000 inside the stack) ---
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_BUCKET_NAME=openkms
AWS_REGION=us-east-1

# --- App URLs / debug ---
OPENKMS_FRONTEND_URL=http://localhost:8082
OPENKMS_DEBUG=true

# --- Document parse (VLM on host; worker uses host.docker.internal) ---
OPENKMS_VLM_URL=http://host.docker.internal:8101
OPENKMS_PIPELINE_TIMEOUT_SECONDS=7200

# --- Baidu Cloud (baidu-doc-parse pipeline; no local VLM) ---
# Required when using pipeline "Baidu Cloud Document Parse" / baidu-doc-parse.
OPENKMS_BAIDU_CLOUD_API_KEY=your-baidu-cloud-api-key
OPENKMS_BAIDU_CLOUD_SECRET_KEY=your-baidu-cloud-secret-key
OPENKMS_BAIDU_BOS_BUCKET=your-baidu-bos-bucket
OPENKMS_BAIDU_BOS_ACCESS_KEY=your-bos-access-key-id
OPENKMS_BAIDU_BOS_SECRET_KEY=your-bos-secret-access-key
# OPENKMS_BAIDU_BOS_ENDPOINT=bj.bcebos.com
# OPENKMS_BAIDU_BOS_PREFIX=openkms-temp
# OPENKMS_BAIDU_BOS_PRESIGN_TTL_SECONDS=3600
# OPENKMS_BAIDU_FILE_URL_SUBMIT_RETRIES=3
# OPENKMS_BAIDU_FILE_URL_RETRY_DELAY_SECONDS=20
# OPENKMS_BAIDU_FILE_URL_SUBMIT_TIMEOUT_SECONDS=600
# Optional endpoint overrides (defaults are Baidu official PaddleOCR-VL URLs):
# BAIDU_TOKEN_URL=https://aip.baidubce.com/oauth/2.0/token
# BAIDU_TASK_URL=https://aip.baidubce.com/rest/2.0/brain/online/v2/paddle-vl-parser/task
# BAIDU_QUERY_URL=https://aip.baidubce.com/rest/2.0/brain/online/v2/paddle-vl-parser/task/query

# --- Optional Langfuse (qa-agent + backend wiki agent) ---
# LANGFUSE_SECRET_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_BASE_URL=
# LANGFUSE_TRACE_STREAMING=true
# LANGFUSE_HEALTHCHECK=true

# Agent workspace: projects_data → /data/projects; agent_skills_data → /data/agent-skills (backend/worker).
